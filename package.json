{
  "name": "sahyatri",
  "version": "1.0.0",
  "private": true,
  "description": "Sahyatri — Carpooling & Fleet Mobility Platform",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "npm install && prisma generate && prisma db push && npm run db:seed",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "jose": "^5.9.6",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.16",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
